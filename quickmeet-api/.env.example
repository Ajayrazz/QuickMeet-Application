# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quickmeet?schema=public"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# Application Server
PORT=3000
ALLOWED_ORIGINS="http://localhost:8081,http://localhost:3000"

# Notification
NOTIFICATION_PROVIDER="console" # Use 'expo' in production

# JWT Authentication
JWT_ACCESS_SECRET="super-secret-access"
JWT_REFRESH_SECRET="super-secret-refresh"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
