{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000",
        "EXPO_PUBLIC_WS_URL": "ws://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://quickmeet-api.onrender.com",
        "EXPO_PUBLIC_WS_URL": "wss://quickmeet-api.onrender.com"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://quickmeet-api.onrender.com",
        "EXPO_PUBLIC_WS_URL": "wss://quickmeet-api.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
